# Comma-separated platform list. Optional — omit to keep legacy single-douyin
# behavior driven by the ARL_DOUYIN_* variables below. Registered values:
# douyin, bilibili. Use "douyin,bilibili" to monitor both concurrently
# (probes run serially each polling cycle, in the listed order).
ARL_PLATFORMS=douyin

ARL_DOUYIN_ROOM_URL=https://live.douyin.com/216681844390
ARL_STREAMER_NAME=柔风亚索（峡谷韩服双千分王者）
ARL_DOUYIN_PROFILE_DIR=data/tmp/chrome-profile
ARL_ALLOW_BROWSER_CAPTURE_FALLBACK=1
ARL_DOUYIN_POLL_INTERVAL_SECONDS=30
ARL_USE_PLAYWRIGHT_PROBE=1
ARL_DOUYIN_PLAYWRIGHT_SCRIPT=scripts/probe_douyin_room.mjs
ARL_DOUYIN_PLAYWRIGHT_TIMEOUT_MS=20000
# Optional. Without this the page DOM only exposes _hd (720p60) signed leaf
# URLs; the higher _uhd / _origin tiers stay unsigned and unrecordable.
# Provide the FULL Cookie header value (multiple "k=v" pairs joined by "; ").
# To copy: Chrome F12 → Network → any request to live.douyin.com → Headers →
# Request Headers → "Cookie:" line → copy the value (everything after the colon).
# When the cookie expires, high-tier signed URLs disappear and the probe
# silently degrades to PR5's _hd (720p60) — there is no explicit cookie-
# expired event since Douyin lacks a clean unauthenticated marker.
ARL_DOUYIN_COOKIE=

# Bilibili — required only when ARL_PLATFORMS includes "bilibili". Pure HTTP
# API path, no Playwright. ffmpeg pulls require Referer: https://live.bilibili.com
# which BilibiliRoomProbe.stream_headers() supplies and the recorder injects
# automatically — no per-platform recorder configuration needed.
ARL_BILIBILI_ROOM_URL=https://live.bilibili.com/<room_id>
ARL_BILIBILI_STREAMER_NAME=<streamer_name>
# Optional. Anonymous Bilibili API calls cap qn at 250 (720p). Set this to
# unlock qn=400 (1080P 蓝光) and, on some accounts, qn=10000 (原画). To copy:
# Chrome F12 → Application → Cookies → live.bilibili.com → SESSDATA →
# copy the Value field only (no "SESSDATA=" prefix). When the cookie
# expires, the API returns code=-101 ("账号未登录") and the probe surfaces
# reason="api_error:code=-101:..." (already classified as
# http_4xx_non_retryable; the failure routes to manual recovery).
ARL_BILIBILI_SESSDATA=

ARL_WINDOWS_AGENT_STATE_FILE=data/tmp/windows-agent-state.json
ARL_WINDOWS_AGENT_EVENT_LOG=data/tmp/windows-agent-events.jsonl
ARL_ORCHESTRATOR_POLL_INTERVAL_SECONDS=5
ARL_ORCHESTRATOR_AGENT_EVENT_LOG=data/tmp/windows-agent-events.jsonl
ARL_ORCHESTRATOR_RECORDER_EVENT_LOG=data/tmp/recorder-events.jsonl
ARL_ORCHESTRATOR_STATE_FILE=data/tmp/orchestrator-state.json
ARL_ORCHESTRATOR_AUDIT_LOG=data/tmp/orchestrator-events.jsonl
ARL_ORCHESTRATOR_AUTO_CREATE_RECORDING_JOB=1
ARL_SUBTITLES_ENABLED=1
ARL_SUBTITLE_PROVIDER=faster-whisper
ARL_WHISPER_MODEL_SIZE=small
ARL_SUBTITLE_LANGUAGE=zh
ARL_RECORDING_ENABLE_FFMPEG=0
ARL_DIRECT_STREAM_TIMEOUT_SECONDS=20
ARL_RECORDING_FFMPEG_MAX_RETRIES=1
ARL_RECORDING_AUTO_RETRY_MAX_ATTEMPTS=2
ARL_BROWSER_CAPTURE_INPUT=
ARL_BROWSER_CAPTURE_FORMAT=auto
ARL_BROWSER_CAPTURE_RESOLUTION=1920x1080
ARL_BROWSER_CAPTURE_FPS=30
ARL_BROWSER_CAPTURE_TIMEOUT_SECONDS=20
ARL_EXPORT_ENABLE_FFMPEG=0
ARL_EXPORT_FFMPEG_PRESET=veryfast
ARL_EXPORT_FFMPEG_CRF=23
ARL_EXPORT_FFMPEG_TIMEOUT_SECONDS=120
ARL_EXPORT_FFMPEG_MAX_RETRIES=1
