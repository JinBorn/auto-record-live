# ============================================================
# auto-record-live 环境变量示例
# 复制为 .env 后按需修改。等号右侧不要加多余空格。
# 布尔值约定：多数开关使用 1=开启、0=关闭。
# ============================================================


# ============================================================
# 1. 平台选择
# ============================================================

# 要监控的平台列表，用英文逗号分隔。
# 可选值：douyin、bilibili。
# 留空或不配置时，为兼容旧配置，会只启用抖音。
# 示例：
#   ARL_PLATFORMS=douyin
#   ARL_PLATFORMS=bilibili
#   ARL_PLATFORMS=douyin,bilibili
ARL_PLATFORMS=douyin


# ============================================================
# 2. 抖音直播间配置
# ============================================================

# 抖音直播间 URL。
ARL_DOUYIN_ROOM_URL=https://live.douyin.com/216681844390

# 主播名称。旧配置名仍叫 ARL_STREAMER_NAME，目前作为抖音 streamer_name 使用。
ARL_STREAMER_NAME=柔风亚索（峡谷韩服双千分王者）

# Playwright/Chrome 持久化用户目录。用于复用浏览器登录态、缓存等。
ARL_DOUYIN_PROFILE_DIR=data/tmp/chrome-profile

# 找不到可录制直链时，是否允许降级到 browser_capture。
# 1=允许，0=不允许。
ARL_ALLOW_BROWSER_CAPTURE_FALLBACK=1

# 抖音探测间隔旧变量。实际 agent 轮询优先看 ARL_AGENT_POLL_INTERVAL_SECONDS；
# 如果未配置 ARL_AGENT_POLL_INTERVAL_SECONDS，才使用这个值。
ARL_DOUYIN_POLL_INTERVAL_SECONDS=30

# 是否使用 Playwright 探测抖音直播间。1=使用，0=只走 HTTP fallback。
ARL_USE_PLAYWRIGHT_PROBE=1

# 抖音 Playwright 探测脚本路径。
ARL_DOUYIN_PLAYWRIGHT_SCRIPT=scripts/probe_douyin_room.mjs

# 抖音 Playwright 探测超时时间，单位毫秒。
ARL_DOUYIN_PLAYWRIGHT_TIMEOUT_MS=20000

# 抖音最低质量层级。默认 uhd，表示要求 1080p 级别。
# 常见层级从高到低大致为：origin、uhd、hd、sd、md、ld。
# 注意：这是探测阶段的候选质量门；最终录制仍会用实际分辨率校验。
ARL_DOUYIN_MIN_QUALITY_TIER=uhd

# 抖音 Cookie，可选。
# 未配置时，页面通常只暴露 _hd（常见 720p60）签名直链，更高的 _uhd/_origin
# 可能是未签名 master playlist，ffmpeg 不能直接录。
# 配置方式：Chrome F12 -> Network -> live.douyin.com 请求 -> Headers ->
# Request Headers -> Cookie，复制冒号后面的完整值，例如：
#   sessionid=xxx; uid=123; ...
ARL_DOUYIN_COOKIE=


# ============================================================
# 3. B 站直播间配置
# ============================================================

# B 站直播间 URL。只有 ARL_PLATFORMS 包含 bilibili 时才需要。
ARL_BILIBILI_ROOM_URL=https://live.bilibili.com/<room_id>

# B 站主播名称。
ARL_BILIBILI_STREAMER_NAME=<streamer_name>

# B 站 SESSDATA，可选。
# 匿名 API 通常最高只到 qn=250（720P）；配置 SESSDATA 后可解锁 qn=400
#（1080P 蓝光），部分账号/直播间可到 qn=10000（原画）。
# 配置方式：Chrome F12 -> Application -> Cookies -> live.bilibili.com ->
# SESSDATA -> 只复制 Value，不要带 "SESSDATA=" 前缀。
ARL_BILIBILI_SESSDATA=

# B 站最低 qn。默认 400，即 1080P 蓝光基线。
# 常见值：250=720P，400=1080P 蓝光，10000=原画。
ARL_BILIBILI_MIN_STREAM_QN=400

# B 站 API 广告码率下限，单位 kbps。默认 4500。
# 这是 B 站 playinfo 元数据中的 advertised bitrate，不是实际录制码率。
# 实际是否低于 1080p 由 recorder 的实际分辨率校验决定。
ARL_BILIBILI_MIN_STREAM_BITRATE_KBPS=4500


# ============================================================
# 4. Windows agent 探测循环
# ============================================================

# agent 状态文件。
ARL_WINDOWS_AGENT_STATE_FILE=data/tmp/windows-agent-state.json

# agent 输出的直播事件 JSONL。
ARL_WINDOWS_AGENT_EVENT_LOG=data/tmp/windows-agent-events.jsonl

# agent 轮询间隔，单位秒。优先级高于 ARL_DOUYIN_POLL_INTERVAL_SECONDS。
ARL_AGENT_POLL_INTERVAL_SECONDS=30

# 调试专用：强制 agent 输出状态。正常运行请留空或注释掉。
# 可选值通常为 live/offline，具体只用于本地测试。
# ARL_AGENT_FORCE_STATE=

# 调试专用：强制使用某个 stream URL。正常运行请留空或注释掉。
# ARL_AGENT_FORCE_STREAM_URL=


# ============================================================
# 5. Orchestrator 编排
# ============================================================

# orchestrator 轮询间隔，单位秒。
ARL_ORCHESTRATOR_POLL_INTERVAL_SECONDS=5

# orchestrator 读取的 agent 事件日志。
ARL_ORCHESTRATOR_AGENT_EVENT_LOG=data/tmp/windows-agent-events.jsonl

# orchestrator 读取的 recorder 审计/事件日志。
ARL_ORCHESTRATOR_RECORDER_EVENT_LOG=data/tmp/recorder-events.jsonl

# orchestrator 状态文件。
ARL_ORCHESTRATOR_STATE_FILE=data/tmp/orchestrator-state.json

# orchestrator 自身审计日志。
ARL_ORCHESTRATOR_AUDIT_LOG=data/tmp/orchestrator-events.jsonl

# 发现 live_started 后是否自动创建 recording job。
# 1=自动创建，0=只记录 session，不自动排录制任务。
ARL_ORCHESTRATOR_AUTO_CREATE_RECORDING_JOB=1


# ============================================================
# 6. Recorder 录制
# ============================================================

# 是否启用 ffmpeg 录制。
# .env 默认 0 比较安全；Windows launcher 会在启动 recorder/orchestrator 时默认
# pin 为 1，除非父 shell 已显式设置 ARL_RECORDING_ENABLE_FFMPEG。
ARL_RECORDING_ENABLE_FFMPEG=0

# 偏好的目标分辨率标签。目前主要用于配置/显示，实际硬门槛见下方实际分辨率校验。
ARL_RECORDING_PREFERRED_RESOLUTION=1080p

# 单段录制时长，单位分钟。
ARL_RECORDING_SEGMENT_MINUTES=30

# 直链录制时长/超时基准，单位秒。ffmpeg direct-stream 会使用该值作为 -t。
ARL_DIRECT_STREAM_TIMEOUT_SECONDS=20

# ffmpeg 单次运行内最大重试次数。当前 recorder 对明确瞬时错误会让出到下一轮 probe，
# 不会在同一个 stale URL 上反复消耗重试。
ARL_RECORDING_FFMPEG_MAX_RETRIES=1

# 跨 recorder run 的自动重试次数上限。
ARL_RECORDING_AUTO_RETRY_MAX_ATTEMPTS=2

# 同一 session 的瞬时失败预算。达到后会升级为 manual recovery。
ARL_RECORDER_SESSION_RETRY_BUDGET=8

# recorder stderr 完整日志保留数量。日志位于 data/tmp/recorder-stderr/。
ARL_RECORDER_STDERR_RETAIN_COUNT=200

# 是否启用实际录制分辨率校验。1=启用，0=关闭。
ARL_RECORDING_VALIDATE_ACTUAL_RESOLUTION=1

# 实际录制结果最低高度。默认 1080；低于该高度视为不可用，会删除半成品 mp4。
ARL_RECORDING_MIN_ACTUAL_RESOLUTION_HEIGHT=1080

# ffprobe 校验实际分辨率的超时时间，单位秒。
ARL_RECORDING_ACTUAL_RESOLUTION_PROBE_TIMEOUT_SECONDS=10


# ============================================================
# 7. Browser capture 录屏兜底
# ============================================================

# 浏览器录屏输入。留空时按平台自动推导：
# Windows/gdigrab -> desktop；Linux/x11grab -> DISPLAY；macOS/avfoundation -> default:none。
ARL_BROWSER_CAPTURE_INPUT=

# 浏览器录屏格式。auto 会按平台选择；也可显式设置 gdigrab/x11grab/avfoundation。
ARL_BROWSER_CAPTURE_FORMAT=auto

# 浏览器录屏分辨率。
ARL_BROWSER_CAPTURE_RESOLUTION=1920x1080

# 浏览器录屏帧率。
ARL_BROWSER_CAPTURE_FPS=30

# 浏览器录屏超时时间，单位秒。
ARL_BROWSER_CAPTURE_TIMEOUT_SECONDS=20


# ============================================================
# 8. Segmenter / 阶段关键词
# ============================================================

# 自定义 LoL 阶段关键词 JSON 文件路径，可选。
# CLI 传入 --stage-keywords-path 时优先级高于该环境变量。
ARL_STAGE_KEYWORDS_PATH=


# ============================================================
# 9. Subtitles 字幕
# ============================================================

# 是否启用字幕阶段。1=启用，0=关闭。
ARL_SUBTITLES_ENABLED=1

# 字幕提供方。默认 faster-whisper；依赖不可用时会降级为占位字幕。
ARL_SUBTITLE_PROVIDER=faster-whisper

# faster-whisper 模型大小，例如 tiny/base/small/medium/large-v3。
ARL_WHISPER_MODEL_SIZE=small

# 字幕语言。中文直播通常使用 zh。
ARL_SUBTITLE_LANGUAGE=zh


# ============================================================
# 10. Exporter 导出
# ============================================================

# 是否启用 ffmpeg 导出。1=启用，0=使用占位导出。
ARL_EXPORT_ENABLE_FFMPEG=0

# ffmpeg 导出 preset。
ARL_EXPORT_FFMPEG_PRESET=veryfast

# ffmpeg 导出 CRF，数值越小质量越高、文件越大。
ARL_EXPORT_FFMPEG_CRF=23

# ffmpeg 导出超时时间，单位秒。
ARL_EXPORT_FFMPEG_TIMEOUT_SECONDS=120

# ffmpeg 导出最大重试次数。
ARL_EXPORT_FFMPEG_MAX_RETRIES=1

# exporter 遇到可重试 ffmpeg 失败时，两次 attempt 之间的初始退避秒数。
ARL_EXPORTER_BACKOFF_INITIAL_SECONDS=2

# exporter attempt 退避秒数上限。
ARL_EXPORTER_BACKOFF_MAX_SECONDS=8

# exporter stderr 完整日志保留数量。日志位于 data/tmp/exporter-stderr/。
ARL_EXPORTER_STDERR_RETAIN_COUNT=200


# ============================================================
# 11. Windows PowerShell launcher 专用
# ============================================================

# Windows launcher 依赖安装模式。
# if-missing=已有 .venv/.deps-ready 时跳过 pip install -e .；
# always=每次启动都强制执行 pip install -e .。
ARL_WIN_INSTALL_MODE=if-missing

# windows-recorder-loop.ps1 的轮询间隔，单位秒。
# 也可用脚本参数 -IntervalSeconds 覆盖。
ARL_RECORDER_INTERVAL_SECONDS=5
