# auto-record-live .env 示例
#
# 复制为 `.env` 后，填入你真实的直播间和登录信息。
# 这里没有列出的选项会使用 `src/arl/config.py` 里的默认值。
# `.env` 不要提交到 git；它可能包含直播间 URL、Cookie 和 SESSDATA。


# ============================================================
# 1. 直播间
# ============================================================

# 要监控的平台：douyin、bilibili，或 douyin,bilibili。
ARL_PLATFORMS=douyin

# 单个抖音直播间。
ARL_DOUYIN_ROOM_URL=https://live.douyin.com/<room_id>
ARL_STREAMER_NAME=<streamer_name>

# 单个 B 站直播间。只有 ARL_PLATFORMS 包含 bilibili 时才需要。
ARL_BILIBILI_ROOM_URL=https://live.bilibili.com/<room_id>
ARL_BILIBILI_STREAMER_NAME=<streamer_name>

# 多直播间模式：使用下面这些英文逗号分隔的复数配置，替代上面的单直播间配置。
# 主播名按位置和直播间一一对应；如果某个位置缺少主播名，会回退到单直播间主播名。
# ARL_DOUYIN_ROOM_URLS=https://live.douyin.com/111,https://live.douyin.com/222
# ARL_DOUYIN_STREAMER_NAMES=douyin-a,douyin-b
# ARL_BILIBILI_ROOM_URLS=https://live.bilibili.com/333,https://live.bilibili.com/444
# ARL_BILIBILI_STREAMER_NAMES=bili-a,bili-b


# ============================================================
# 2. 登录与画质
# ============================================================

# 可选：抖音完整 Cookie header 值。
# 从浏览器开发者工具里复制 Request Headers 的 Cookie 值，例如：
# sessionid=xxx; uid=123; ...
ARL_DOUYIN_COOKIE=

# 可选：B 站 SESSDATA 值。只复制 Cookie 的 value，不要带 "SESSDATA=" 前缀。
ARL_BILIBILI_SESSDATA=

# 画质门槛通常不需要修改。只有明确要调整画质要求时，再按需取消注释。
# ARL_DOUYIN_MIN_QUALITY_TIER=uhd
# ARL_BILIBILI_MIN_STREAM_QN=400
# ARL_BILIBILI_MIN_STREAM_BITRATE_KBPS=4500


# ============================================================
# 3. 轮询与负载
# ============================================================

# 调大轮询间隔可以降低无人值守运行时的 CPU 和网络压力。
ARL_AGENT_POLL_INTERVAL_SECONDS=90
ARL_ORCHESTRATOR_POLL_INTERVAL_SECONDS=10
ARL_RECORDER_INTERVAL_SECONDS=5
ARL_POSTPROCESS_INTERVAL_SECONDS=30
ARL_RECOVERY_INTERVAL_SECONDS=30

# 单次 recorder run 最多同时执行多少个 ffmpeg 录制任务。
# 普通电脑建议从 1 开始；多直播间同时开播时可按机器能力调到 2。
ARL_RECORDER_MAX_CONCURRENT_JOBS=1


# ============================================================
# 4. 录制与后处理
# ============================================================

# 手动执行 `arl recorder` 时，1 表示真实 ffmpeg 录制，0 表示写占位文件。
# Windows recorder/orchestrator launcher 默认会把它设为 1，除非父 shell 已经显式设置。
ARL_RECORDING_ENABLE_FFMPEG=0

# 直链录制预算，单位秒。正式长录制可设置得更长，例如 7200 表示约 2 小时。
ARL_DIRECT_STREAM_TIMEOUT_SECONDS=20

# Optional segmented direct-stream recording. Keep disabled until downstream
# chunk-aware postprocess stages are enabled.
# ARL_RECORDING_SEGMENTED_ENABLED=0
# ARL_RECORDING_SEGMENTED_CHUNK_SECONDS=900

# 用于阶段提示生成和兜底分段节奏，单位分钟。
ARL_RECORDING_SEGMENT_MINUTES=30
# 无字幕/语义信号时是否启用固定周期模板切片。默认关闭，避免把 30 分钟硬切误认为自动剪辑。
# ARL_SEGMENTER_TEMPLATE_FALLBACK_ENABLED=0

# 字幕默认开启。tiny/base/small 可在速度和质量之间取舍；
# 如果要跳过 ASR 字幕计算，设为 ARL_SUBTITLES_ENABLED=0。
ARL_SUBTITLES_ENABLED=1
ARL_WHISPER_MODEL_SIZE=small

# 1 表示导出真实烧录字幕视频；0 表示写轻量占位导出文件。
ARL_EXPORT_ENABLE_FFMPEG=0

# Optional publish-edit preset for unattended postprocess loops.
# Set to publish to enable condensed edit plans, ASS subtitle burn-in,
# chat-target zoom, and low-volume default BGM/SFX together.
# ARL_POSTPROCESS_PRESET=publish
# Keep enabled to avoid adding BGM over livestream recordings that already
# contain a persistent music bed.
# ARL_EDIT_SKIP_BGM_WHEN_SOURCE_HAS_MUSIC=1
# Optional JSON manifest for automatic BGM matching. If unset or unmatched,
# the planner falls back to generated default BGM.
# ARL_EDIT_BGM_LIBRARY_PATH=data/bgm/library.json
# Long exports can use laning -> momentum -> climax phases when the library has
# distinct tracks. Crossfades are represented as overlapping edit-plan beds.
# ARL_EDIT_BGM_MULTI_PHASE_MIN_SECONDS=600
# ARL_EDIT_BGM_SWITCH_MIN_GAP_SECONDS=60
# ARL_EDIT_BGM_CROSSFADE_SECONDS=2
# Source music is suppressed by detected span, unless it covers most BGM-active
# output, in which case BGM is skipped for the match.
# ARL_EDIT_BGM_SOURCE_MUSIC_PADDING_SECONDS=2
# ARL_EDIT_BGM_SOURCE_MUSIC_MAJORITY_THRESHOLD=0.60
# Optional SFX manifest for kill, multi-kill, transition, and teaser impact
# sounds. Missing or invalid manifests fall back to generated coin SFX.
# ARL_EDIT_SFX_LIBRARY_PATH=data/sfx/library.json
# ARL_EDIT_SFX_TIMING_OFFSET_SECONDS=0
# ARL_EDIT_SFX_MIN_INTERVAL_SECONDS=20
# ARL_EDIT_SFX_MAX_HITS=6
# ARL_EDIT_SFX_KDA_ALIGNMENT_ENABLED=1
# ARL_EDIT_SFX_MULTIKILL_WINDOW_SECONDS=8
# Optional zoom close-up controls. Publish preset defaults max segments to 3
# unless ARL_EDIT_ZOOM_MAX_SEGMENTS is explicitly set.
# ARL_EDIT_ZOOM_ENABLED=0
# ARL_EDIT_ZOOM_MODE=closeup
# ARL_EDIT_ZOOM_TARGET=chat
# ARL_EDIT_ZOOM_SCALE=1.2
# ARL_EDIT_ZOOM_X_ANCHOR=0.5
# ARL_EDIT_ZOOM_Y_ANCHOR=0.5
# ARL_EDIT_ZOOM_MAX_SEGMENTS=3
# ARL_EDIT_ZOOM_CLOSEUP_SECONDS=6
# ARL_EDIT_ZOOM_EASE_SECONDS=0.4
# ARL_EDIT_ZOOM_MIN_INTERVAL_SECONDS=25
# ARL_EDIT_ZOOM_CHAT_BURST_ENABLED=1
# ARL_EDIT_ZOOM_CHAT_BURST_SAMPLE_INTERVAL_SECONDS=0.5
# ARL_EDIT_ZOOM_CHAT_BURST_THRESHOLD=0.08
# ARL_EDIT_ZOOM_MAX_DURATION_SECONDS=30
# Optional teaser and transition controls used by edit plans.
# Publish preset defaults ARL_EDIT_TRANSITION_MODE to black_card unless an
# explicit mode is set before loading settings.
# ARL_EDIT_TEASER_DYNAMIC_BUDGET_ENABLED=1
# ARL_EDIT_TEASER_BUDGET_FRACTION_MIN=0.08
# ARL_EDIT_TEASER_BUDGET_FRACTION_MAX=0.12
# ARL_EDIT_TEASER_BUDGET_MIN_SECONDS=20
# ARL_EDIT_TEASER_BUDGET_MAX_SECONDS=90
# ARL_EDIT_TEASER_CANDIDATE_REASONS=highlight_keyword,condensed_key_event
# ARL_EDIT_TEASER_FALLBACK_ENABLED=1
# ARL_EDIT_TRANSITION_MODE=none
# ARL_EDIT_TRANSITION_DURATION_SECONDS=1.25
# ARL_EDIT_TRANSITION_TEXT=Back to match start
# ARL_EDIT_TRANSITION_SFX_PATH=data/sfx/tracks/whoosh.wav
# ARL_EDIT_TRANSITION_SFX_GAIN_DB=-12

# Optional cloud LLM copywriter. Disabled by default; publish preset does not
# enable it. Set both ARL_LLM_ENABLED=1 and ARL_LLM_API_KEY to generate semantic
# teaser hints before edit planning and final upload copy after export.
# DeepSeek OpenAI-compatible endpoint:
# ARL_LLM_BASE_URL=https://api.deepseek.com/v1
# ARL_LLM_MODEL=deepseek-chat
# Qwen DashScope OpenAI-compatible endpoint:
# ARL_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ARL_LLM_MODEL=qwen-plus
# Anthropic OpenAI-compatible endpoint:
# ARL_LLM_BASE_URL=https://api.anthropic.com/v1
# ARL_LLM_MODEL=claude-sonnet-4-20250514
# ARL_LLM_ENABLED=0
# ARL_LLM_API_KEY=
# ARL_LLM_TIMEOUT_SECONDS=30
# ARL_LLM_MAX_RETRIES=2
# ARL_LLM_MAX_INPUT_CUES=160
# ARL_LLM_TEMPERATURE=0.4
# Shared story/highlight semantics. Shadow mode records recommendations without
# changing the final edit plan or publishing package.
# ARL_LLM_STORY_ANALYSIS_ENABLED=0
# ARL_LLM_STORY_SHADOW_MODE=1
# ARL_HIGHLIGHT_SEMANTIC_WEIGHT=0.25
# ARL_LLM_SEMANTIC_SCHEMA_VERSION=2


# ============================================================
# 5. Windows launcher
# ============================================================

# if-missing 表示 .venv/.deps-ready 有效后跳过依赖重装。
ARL_WIN_INSTALL_MODE=if-missing

# warning 表示 Cookie 健康检查异常时打印提醒并继续；
# fatal 表示异常时退出；skip 表示关闭启动时 Cookie 检查。
ARL_COOKIE_HEALTH_GATE=warning


# 低频高级覆盖项，需要时再添加：
# ARL_DOUYIN_PROFILE_DIR=data/tmp/chrome-profile
# GTX 1650 4GB friendly stable ASR settings:
# Publish preset defaults CUDA/auto ASR to medium unless ARL_WHISPER_MODEL_SIZE is set.
# CPU-only ASR still defaults to small. large-v3 remains opt-in.
# ARL_WHISPER_MODEL_SIZE=medium
# ARL_WHISPER_DEVICE=auto
# ARL_WHISPER_COMPUTE_TYPE=auto
# ARL_WHISPER_CUDA_COMPUTE_TYPE=int8_float16
# ARL_WHISPER_CPU_COMPUTE_TYPE=int8
# ARL_WHISPER_MODEL_CACHE_DIR=data/tmp/whisper-models
# ARL_WHISPER_BEAM_SIZE=5
# ARL_WHISPER_VAD_FILTER=1
# ARL_WHISPER_VAD_MIN_SILENCE_DURATION_MS=300
# ARL_WHISPER_VAD_SPEECH_PAD_MS=250
# ARL_ASR_PREPROCESS_AUDIO=1
# ARL_ASR_PREPROCESS_TIMEOUT_SECONDS=120
# ARL_ASR_PREPROCESS_AUDIO_FILTER=highpass=f=80,lowpass=f=7800,afftdn=nf=-25,loudnorm=I=-16:TP=-1.5:LRA=11
# ARL_ASR_OPENCC_ENABLED=1
# ARL_ASR_INITIAL_PROMPT_PATH=data/asr/initial-prompt.txt
# ARL_ASR_INITIAL_PROMPT_MAX_CHARS=1200
# ARL_ASR_TERM_FIXES_PATH=data/asr/term-fixes.json
# ARL_ASR_DISPLAY_SMOOTHING_ENABLED=1
# ARL_ASR_DISPLAY_MIN_DURATION_SECONDS=3.5
# ARL_ASR_DISPLAY_TRAILING_HOLD_SECONDS=1.25
# ARL_ASR_DISPLAY_MAX_GAP_FILL_SECONDS=8
# auto keeps stream-copy exports when possible; h265 transcodes final exports to HEVC.
# ARL_EXPORT_FFMPEG_VIDEO_CODEC=h265
# Keep ASR subtitles for planning/copy, but set 0 to avoid burning imperfect subtitles into final video.
# ARL_EXPORT_BURN_SUBTITLES=0
# ARL_EXPORT_FFMPEG_PRESET=veryfast
# ARL_EXPORT_FFMPEG_CRF=23
# ARL_MAINTENANCE_MAX_JSONL_BYTES=52428800
