# auto-record-live .env 示例
#
# 复制为 `.env` 后，填入你真实的直播间和登录信息。
# 这里没有列出的选项会使用 `src/arl/config.py` 里的默认值。
# `.env` 不要提交到 git；它可能包含直播间 URL、Cookie 和 SESSDATA。


# ============================================================
# 1. 直播间
# ============================================================

# 要监控的平台：douyin、bilibili，或 douyin,bilibili。
ARL_PLATFORMS=douyin

# 单个抖音直播间。
ARL_DOUYIN_ROOM_URL=https://live.douyin.com/<room_id>
ARL_STREAMER_NAME=<streamer_name>

# 单个 B 站直播间。只有 ARL_PLATFORMS 包含 bilibili 时才需要。
ARL_BILIBILI_ROOM_URL=https://live.bilibili.com/<room_id>
ARL_BILIBILI_STREAMER_NAME=<streamer_name>

# 多直播间模式：使用下面这些英文逗号分隔的复数配置，替代上面的单直播间配置。
# 主播名按位置和直播间一一对应；如果某个位置缺少主播名，会回退到单直播间主播名。
# ARL_DOUYIN_ROOM_URLS=https://live.douyin.com/111,https://live.douyin.com/222
# ARL_DOUYIN_STREAMER_NAMES=douyin-a,douyin-b
# ARL_BILIBILI_ROOM_URLS=https://live.bilibili.com/333,https://live.bilibili.com/444
# ARL_BILIBILI_STREAMER_NAMES=bili-a,bili-b


# ============================================================
# 2. 登录与画质
# ============================================================

# 可选：抖音完整 Cookie header 值。
# 从浏览器开发者工具里复制 Request Headers 的 Cookie 值，例如：
# sessionid=xxx; uid=123; ...
ARL_DOUYIN_COOKIE=

# 可选：B 站 SESSDATA 值。只复制 Cookie 的 value，不要带 "SESSDATA=" 前缀。
ARL_BILIBILI_SESSDATA=

# 画质门槛通常不需要修改。只有明确要调整画质要求时，再按需取消注释。
# ARL_DOUYIN_MIN_QUALITY_TIER=uhd
# ARL_BILIBILI_MIN_STREAM_QN=400
# ARL_BILIBILI_MIN_STREAM_BITRATE_KBPS=4500


# ============================================================
# 3. 轮询与负载
# ============================================================

# 调大轮询间隔可以降低无人值守运行时的 CPU 和网络压力。
ARL_AGENT_POLL_INTERVAL_SECONDS=90
ARL_ORCHESTRATOR_POLL_INTERVAL_SECONDS=10
ARL_RECORDER_INTERVAL_SECONDS=5
ARL_POSTPROCESS_INTERVAL_SECONDS=30
ARL_RECOVERY_INTERVAL_SECONDS=30

# 单次 recorder run 最多同时执行多少个 ffmpeg 录制任务。
# 普通电脑建议从 1 开始；多直播间同时开播时可按机器能力调到 2。
ARL_RECORDER_MAX_CONCURRENT_JOBS=1


# ============================================================
# 4. 录制与后处理
# ============================================================

# 手动执行 `arl recorder` 时，1 表示真实 ffmpeg 录制，0 表示写占位文件。
# Windows recorder/orchestrator launcher 默认会把它设为 1，除非父 shell 已经显式设置。
ARL_RECORDING_ENABLE_FFMPEG=0

# 直链录制预算，单位秒。正式长录制可设置得更长，例如 7200 表示约 2 小时。
ARL_DIRECT_STREAM_TIMEOUT_SECONDS=20

# 用于阶段提示生成和兜底分段节奏，单位分钟。
ARL_RECORDING_SEGMENT_MINUTES=30

# 字幕默认开启。tiny/base/small 可在速度和质量之间取舍；
# 如果要跳过 ASR 字幕计算，设为 ARL_SUBTITLES_ENABLED=0。
ARL_SUBTITLES_ENABLED=1
ARL_WHISPER_MODEL_SIZE=small

# 1 表示导出真实烧录字幕视频；0 表示写轻量占位导出文件。
ARL_EXPORT_ENABLE_FFMPEG=0


# ============================================================
# 5. Windows launcher
# ============================================================

# if-missing 表示 .venv/.deps-ready 有效后跳过依赖重装。
ARL_WIN_INSTALL_MODE=if-missing

# warning 表示 Cookie 健康检查异常时打印提醒并继续；
# fatal 表示异常时退出；skip 表示关闭启动时 Cookie 检查。
ARL_COOKIE_HEALTH_GATE=warning


# 低频高级覆盖项，需要时再添加：
# ARL_DOUYIN_PROFILE_DIR=data/tmp/chrome-profile
# ARL_WHISPER_DEVICE=auto
# ARL_WHISPER_MODEL_CACHE_DIR=data/tmp/whisper-models
# ARL_EXPORT_FFMPEG_PRESET=veryfast
# ARL_EXPORT_FFMPEG_CRF=23
# ARL_MAINTENANCE_MAX_JSONL_BYTES=52428800
